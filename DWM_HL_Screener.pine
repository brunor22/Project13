// version 3.0

// @version=6
indicator("Screener: MasterListFilter", "MasterList", true, max_lines_count=500)

//--------------------------------------------------------------------
//                             Constants
//--------------------------------------------------------------------

var DAILY_LINE_STYLE    = line.style_solid
var DAILY_LINE_WITDH    = 1
var WEEKLY_LINE_STYLE   = line.style_solid
var WEEKLY_LINE_WIDTH   = 2
var MONTHLY_LINE_STYLE  = line.style_solid
var MONTHLY_LINE_WIDTH  = 6

//--------------------------------------------------------------------
//                               Inputs
//--------------------------------------------------------------------

g_indicator             = "Highs & Lows"
g_style                 = "Style"
g_vwap                  = "Moving VWAP"
g_hilo                  = "HiLo Range"
t_heads                 = "Extends previous highs and lows in the future."
t_gradient              = "Show a color gradient that highlights the recency of highs and lows."

var i_isDailyEnabled    = input     (true,          "Daily",                        inline="Daily",     group=g_indicator)
var i_dailyColor        = input     (color.green,   "",                             inline="Daily",     group=g_indicator)
var i_dailyLookback     = input.int (2,             "", 1,                          inline="Daily",     group=g_indicator)
var i_isWeeklyEnabled   = input     (true,          "Weekly",                       inline="Weekly",    group=g_indicator)
var i_weeklyColor       = input     (color.orange,  "",                             inline="Weekly",    group=g_indicator)
var i_weeklyLookback    = input.int (1,             "", 1,                          inline="Weekly",    group=g_indicator)
var i_isMonthlyEnabled  = input     (true,          "Monthly",                      inline="Monthly",   group=g_indicator)
var i_monthlyColor      = input     (color.red,     "",                             inline="Monthly",   group=g_indicator)
var i_monthlyLookback   = input.int (1,             "", 1,                          inline="Monthly",   group=g_indicator)
var i_areHeadsEnabled   = input     (false,         "Show Projections", t_heads,    inline="Head",      group=g_style)
var i_rightOffset       = input.int (20,            "", 1,                          inline="Head",      group=g_style)
var i_hasGradient       = input     (true,          "Show Gradient",    t_gradient,                     group=g_style)

hiloLookback            = input.int (20,            "Lookback",         minval=1,                       group=g_hilo)

cumulativePeriod1       = input.int (14,            "VWAP Period 1",    minval=1,                       group=g_vwap)
cumulativePeriod2       = input.int (28,            "VWAP Period 2",    minval=1,                       group=g_vwap)
LineWidth               = input.int (2,             "Line Width",       minval=1,                       group=g_vwap)
maxCrossLines           = input.int (1,             "Crossover Lines to Show", minval=1, maxval=20,     group=g_vwap)
lineOffset              = input.float(0.0,          "Cross Line Price Offset", step=0.01,               group=g_vwap)

//--------------------------------------------------------------------
//                        Variables declarations
//--------------------------------------------------------------------

var a_lastHighs                         = array.new_float(3)
var a_lastLows                          = array.new_float(3)
var canShowDaily                        = i_isDailyEnabled and timeframe.isintraday
var canShowWeekly                       = i_isWeeklyEnabled and (timeframe.isintraday or timeframe.isdaily)
var canShowMonthly                      = i_isMonthlyEnabled and not timeframe.ismonthly

//[dailyTime, dailyHigh, dailyLow, isLastDaily]           = request.security(syminfo.tickerid, 'D', [time, high, low, barstate.islast], lookahead=barmerge.lookahead_on)
[weeklyTime, weeklyHigh, weeklyLow, isLastWeekly]       = request.security(syminfo.tickerid, 'W', [time, high, low, barstate.islast], lookahead=barmerge.lookahead_on)
[monthlyTime, monthlyHigh, monthlyLow, isLastMonthly]   = request.security(syminfo.tickerid, 'M', [time, high, low, barstate.islast], lookahead=barmerge.lookahead_on)

//hasDailyTimeChanged                     = dailyTime != dailyTime[1]
hasWeekklyTimeChanged                   = weeklyTime != weeklyTime[1]
hasMonthlyTimeChanged                   = monthlyTime != monthlyTime[1]

//--------------------------------------------------------------------
//                              Functions
//--------------------------------------------------------------------

f_getRightBarIndex() => bar_index + i_rightOffset

f_draw(bool _isNew, float _h, float _l, int _lookback, color _color, string _style, int _width) =>
    var line _high  = na
    var line _low   = na
    var _highs      = array.new_line()
    var _lows       = array.new_line()
    _end            = i_areHeadsEnabled ? f_getRightBarIndex() : bar_index

    if _isNew
        line.set_x2(_high, _end)
        line.set_x2(_low, _end)

        if i_hasGradient
            _size = array.size(_highs)
            if _size > 1
                for i = 0 to _size - 1
                    _c = color.from_gradient(i, 0, _size - 1, color.new(_color, 100), color.new(_color, 0))
                    line.set_color(array.get(_highs, i), _c)
                    line.set_color(array.get(_lows, i), _c)

        _high := line.new(bar_index, _h, bar_index, _h, color=_color, style=_style, width=_width)
        _low := line.new(bar_index, _l, bar_index, _l, color=_color, style=_style, width=_width)
        array.push(_highs, _high)
        array.push(_lows, _low)

        if array.size(_highs) > _lookback + 1
            line.delete(array.shift(_highs))
            line.delete(array.shift(_lows))

	if i_areHeadsEnabled and barstate.islast and array.size(_highs) > 1
		// Avoid updating the last/current high and low
		for i = 0 to array.size(_highs) - 2
			line.set_x2(array.get(_highs, i), f_getRightBarIndex())
			line.set_x2(array.get(_lows, i), f_getRightBarIndex())

//--------------------------------------------------------------------
//                                Logic
//--------------------------------------------------------------------

//if canShowDaily and hasDailyTimeChanged and not isLastDaily
//	array.set(a_lastHighs, 0, dailyHigh)
//	array.set(a_lastLows, 0, dailyLow)

if canShowWeekly and hasWeekklyTimeChanged and not isLastWeekly
	array.set(a_lastHighs, 1, weeklyHigh)
	array.set(a_lastLows, 1, weeklyLow)

if canShowMonthly and hasMonthlyTimeChanged and not isLastMonthly
	array.set(a_lastHighs, 2, monthlyHigh)
	array.set(a_lastLows, 2, monthlyLow)

//--------------------------------------------------------------------
//                          Plotting & styling
//--------------------------------------------------------------------

if canShowMonthly
    f_draw(hasMonthlyTimeChanged, monthlyHigh, monthlyLow, i_monthlyLookback, i_monthlyColor, MONTHLY_LINE_STYLE, MONTHLY_LINE_WIDTH)

if canShowWeekly
    f_draw(hasWeekklyTimeChanged, weeklyHigh, weeklyLow, i_weeklyLookback, i_weeklyColor, WEEKLY_LINE_STYLE, WEEKLY_LINE_WIDTH)

//if canShowDaily
//    f_draw(hasDailyTimeChanged, dailyHigh, dailyLow, i_dailyLookback, i_dailyColor, DAILY_LINE_STYLE, DAILY_LINE_WITDH)

// Plot invisible highs and lows for displaying their last values in `status line`, `scale`, `data window` as well for providing defaults alert conditions

is_price_above_MH = close > array.get(a_lastHighs, 2) ? 1:0
is_price_below_ML = close < array.get(a_lastLows, 2) ? 1:0

is_price_above_WH = close > array.get(a_lastHighs, 1) ? 1:0
is_price_below_WL = close < array.get(a_lastLows, 1) ? 1:0

plot(close, "Close")
plot(array.get(a_lastHighs, 1), "WH",   color.new(i_weeklyColor, 100),  editable=true)
plot(array.get(a_lastLows, 1),  "WL",   color.new(i_weeklyColor, 100),  editable=true)
plot(array.get(a_lastHighs, 2), "MH",   color.new(i_monthlyColor, 100), editable=true)
plot(array.get(a_lastLows, 2),  "ML",   color.new(i_monthlyColor, 100), editable=true)

plot(is_price_above_MH, title = "Above MH", color = color.blue)
plot(is_price_below_ML, title = "Below ML", color = color.red)

plot(is_price_above_WH, title = "Above WH", color = color.blue)
plot(is_price_below_WL, title = "Below WL", color = color.red)

//--------------------------------------------------------------------
//                          Moving VWAP Logic
//--------------------------------------------------------------------

// Typical price
typicalPrice       = (open + high + low + close) / 4
typicalPriceVolume = typicalPrice * volume

// Moving VWAP – Period 1
vwapValue1 = math.sum(typicalPriceVolume, cumulativePeriod1) / math.sum(volume, cumulativePeriod1)

// Moving VWAP – Period 2
vwapValue2 = math.sum(typicalPriceVolume, cumulativePeriod2) / math.sum(volume, cumulativePeriod2)

// Crossover / crossunder detection (evaluated unconditionally every bar)
isCrossover  = ta.crossover(vwapValue1, vwapValue2)
isCrossunder = ta.crossunder(vwapValue1, vwapValue2)

// Persist line color across bars
var color lineColor = na
lineColor := isCrossover  ? color.green :
             isCrossunder ? color.red   :
             nz(lineColor, vwapValue1 >= vwapValue2 ? color.green : color.red)

// Plot VWAP line (visible on chart overlay)
plot(vwapValue1, title="Moving VWAP 1", color=lineColor, linewidth=LineWidth)

// ── Horizontal crossover/crossunder lines projected to the right ────────────
var line[]  crossoverLines  = array.new_line()
var float[] crossoverPrices = array.new_float()

// Terminate lines touched by price (iterate in reverse to allow safe removal)
if array.size(crossoverLines) > 0
    for i = array.size(crossoverLines) - 1 to 0
        lvl = array.get(crossoverPrices, i)
        if high >= lvl and low <= lvl
            l = array.get(crossoverLines, i)
            line.set_extend(l, extend.none)
            line.set_x2(l, bar_index)
            array.remove(crossoverLines, i)
            array.remove(crossoverPrices, i)

// Draw a new horizontal line on each crossover / crossunder
if isCrossover or isCrossunder
    crossColor = isCrossover ? color.rgb(76, 175, 79, 75) : color.rgb(255, 82, 82, 75)
    crossPrice = vwapValue1[1] + (isCrossover ? lineOffset : -lineOffset)

    newLine = line.new(
         x1     = bar_index - 1,
         y1     = crossPrice,
         x2     = bar_index,
         y2     = crossPrice,
         extend = extend.right,
         color  = crossColor,
         style  = line.style_solid,
         width  = 4)

    array.push(crossoverLines,  newLine)
    array.push(crossoverPrices, crossPrice)

    // Evict oldest lines that exceed the user-defined limit
    while array.size(crossoverLines) > maxCrossLines
        line.delete(array.shift(crossoverLines))
        array.shift(crossoverPrices)

//--------------------------------------------------------------------
//                    Moving VWAP Screener Columns
//--------------------------------------------------------------------

// Numeric signal: 1 = bullish (VWAP1 above VWAP2), -1 = bearish, 0 = flat
vwapTrend = vwapValue1 > vwapValue2 ? 1 : vwapValue1 < vwapValue2 ? -1 : 0

// Price position relative to each VWAP
is_above_vwap1 = close > vwapValue1 ? 1 : 0
is_above_vwap2 = close > vwapValue2 ? 1 : 0

plot(vwapValue1,     title="VWAP 1",           color=color.new(#00897b, 0), editable=true)
plot(vwapValue2,     title="VWAP 2",           color=color.new(#9b27b0, 0), editable=true)
plot(vwapTrend,      title="VWAP Trend",       color=color.new(color.teal,   0), editable=true)
plot(isCrossover  ? 1 : 0, title="VWAP Crossover",  color=color.new(color.green, 0), editable=true)
plot(isCrossunder ? 1 : 0, title="VWAP Crossunder", color=color.new(color.red,   0), editable=true)
plot(is_above_vwap1, title="Above VWAP 1",    color=color.new(color.teal,   0), editable=true)
plot(is_above_vwap2, title="Above VWAP 2",    color=color.new(color.purple, 0), editable=true)

//--------------------------------------------------------------------
//                        Market Cap Column
//--------------------------------------------------------------------

sharesOutstanding = request.financial(syminfo.tickerid, "TOTAL_SHARES_OUTSTANDING", "FQ", gaps=barmerge.gaps_off, ignore_invalid_symbol=true)
marketCap = close * sharesOutstanding

plot(marketCap, title="Market Cap", color=color.new(#1447df, 0), editable=true)

//--------------------------------------------------------------------
//                        Volume Column
//--------------------------------------------------------------------

plot(volume, title="Volume", color=color.new(#1044e2, 0), editable=true)

//--------------------------------------------------------------------
//                        HiLo Range Columns
//--------------------------------------------------------------------

hiloHigh   = ta.highest(hiloLookback)
hiloLow    = ta.lowest(hiloLookback)
hiloPct    = (hiloHigh - hiloLow) != 0 ? (close - hiloLow) / (hiloHigh - hiloLow) * 100 : 0.0

plot(hiloHigh, title="Period High",      color=color.new(color.blue,  0), editable=true)
plot(hiloLow,  title="Period Low",       color=color.new(color.blue,  0), editable=true)
plot(hiloPct,  title="% in HiLo Range", color=color.new(color.blue,  0), editable=true)

//--------------------------------------------------------------------
//                        Sector Column
// FactSet Economic Sector classification as used by TradingView.
// Codes 1-20. 0 = unknown / not applicable.
//--------------------------------------------------------------------

sectorCode = switch syminfo.sector
    "Non-Energy Minerals"    => 1
    "Producer Manufacturing" => 2
    "Electronic Technology"  => 3
    "Consumer Durables"      => 4
    "Energy Minerals"        => 5
    "Process Industries"     => 6
    "Health Technology"      => 7
    "Consumer Non-Durables"  => 8
    "Industrial Services"    => 9
    "Commercial Services"    => 10
    "Distribution Services"  => 11
    "Technology Services"    => 12
    "Health Services"        => 13
    "Consumer Services"      => 14
    "Retail Trade"           => 15
    "Transportation"         => 16
    "Utilities"              => 17
    "Finance"                => 18
    "Communications"         => 19
    "Miscellaneous"          => 20
    => 0

plot(sectorCode, title="Sector", color=color.new(#1447df, 0), editable=true)

//--------------------------------------------------------------------
//                        Industry Column
// FactSet Industry classification as used by TradingView.
// Codes grouped by sector (sector * 100 + sequence). 0 = unknown.
//--------------------------------------------------------------------

industryCode = switch syminfo.industry
    // Non-Energy Minerals (1xx)
    "Steel"                               => 101
    "Aluminum"                            => 102
    "Precious Metals"                     => 103
    "Other Metals/Minerals"               => 104
    "Forest Products"                     => 105
    "Construction Materials"              => 106
    // Producer Manufacturing (2xx)
    "Metal Fabrication"                   => 201
    "Industrial Machinery"                => 202
    "Trucks/Construction/Farm Machinery"  => 203
    "Auto Parts: OEM"                     => 204
    "Building Products"                   => 205
    "Electrical Products"                 => 206
    "Office Equipment/Supplies"           => 207
    "Miscellaneous Manufacturing"         => 208
    "Industrial Conglomerates"            => 209
    // Electronic Technology (3xx)
    "Semiconductors"                      => 301
    "Electronic Components"               => 302
    "Electronic Equipment/Instruments"    => 303
    "Telecommunications Equipment"        => 304
    "Aerospace & Defense"                 => 305
    "Computer Processing Hardware"        => 306
    "Computer Peripherals"                => 307
    "Computer Communications"             => 308
    "Electronic Production Equipment"     => 309
    // Consumer Durables (4xx)
    "Motor Vehicles"                      => 401
    "Automotive Aftermarket"              => 402
    "Homebuilding"                        => 403
    "Home Furnishings"                    => 404
    "Electronics/Appliances"              => 405
    "Tools & Hardware"                    => 406
    "Recreational Products"               => 407
    "Other Consumer Specialties"          => 408
    // Energy Minerals (5xx)
    "Oil and Gas Production"              => 501
    "Integrated Oil"                      => 502
    "Oil Refining/Marketing"              => 503
    "Coal"                                => 504
    // Process Industries (6xx)
    "Chemicals: Major Diversified"        => 601
    "Chemicals: Specialty"                => 602
    "Chemicals: Agricultural"             => 603
    "Textiles"                            => 604
    "Agricultural Commodities/Milling"    => 605
    "Pulp and Paper"                      => 606
    "Containers/Packaging"                => 607
    "Industrial Specialities"             => 608
    // Health Technology (7xx)
    "Pharmaceuticals: Major"              => 701
    "Pharmaceuticals: Other"              => 702
    "Pharmaceuticals: Generic"            => 703
    "Biotechnology"                       => 704
    "Medical Specialties"                 => 705
    // Consumer Non-Durables (8xx)
    "Food: Major Diversified"             => 801
    "Food: Specialty/Candy"               => 802
    "Food: Meat/Fish/Dairy"               => 803
    "Beverages: Non-Alcoholic"            => 804
    "Beverages: Alcoholic"                => 805
    "Tobacco"                             => 806
    "Household/Personal Care"             => 807
    "Apparel/Footwear"                    => 808
    "Consumer Sundries"                   => 809
    // Industrial Services (9xx)
    "Contract Drilling"                   => 901
    "Oilfield Services/Equipment"         => 902
    "Engineering and Construction"        => 903
    "Environmental Services"              => 904
    "Oil and Gas Pipelines"               => 905
    // Commercial Services (10xx)
    "Miscellaneous Commercial Services"   => 1001
    "Advertising /Marketing Services"     => 1002
    "Commercial Printing/Forms"           => 1003
    "Financial Publishing/Services"       => 1004
    "Personnel Services"                  => 1005
    // Distribution Services (11xx)
    "Wholesale Distributors"              => 1101
    "Food Distributors"                   => 1102
    "Electronics Distributors"            => 1103
    "Medical Distributors"                => 1104
    // Technology Services (12xx)
    "Data Processing Services"            => 1201
    "Information Technology Services"     => 1202
    "Packaged Software"                   => 1203
    "Internet Software/Services"          => 1204
    // Health Services (13xx)
    "Managed Health Care"                 => 1301
    "Hospital/Nursing Management"         => 1302
    "Medical/Nursing Services"            => 1303
    "Services to the Health Industry"     => 1304
    // Consumer Services (14xx)
    "Media Conglomerates"                 => 1401
    "Broadcasting"                        => 1402
    "Cable/Satellite TV"                  => 1403
    "Publishing: Newspapers"              => 1404
    "Publishing: Books/Magazines"         => 1405
    "Movies/Entertainment"                => 1406
    "Restaurants"                         => 1407
    "Hotels/Resorts/Cruiselines"          => 1408
    "Casinos/Gaming"                      => 1409
    "Other Consumer Services"             => 1410
    // Retail Trade (15xx)
    "Food Retail"                         => 1501
    "Drugstore Chains"                    => 1502
    "Department Stores"                   => 1503
    "Discount Stores"                     => 1504
    "Apparel/Footwear Retail"             => 1505
    "Home Improvement Chains"             => 1506
    "Electronics/Appliance Stores"        => 1507
    "Specialty Stores"                    => 1508
    "Catalogs/Specialty Distribution"     => 1509
    "Internet Retail"                     => 1510
    // Transportation (16xx)
    "Air Freight/Couriers"                => 1601
    "Airlines"                            => 1602
    "Trucking"                            => 1603
    "Railroads"                           => 1604
    "Marine Shipping"                     => 1605
    "Other Transportation"                => 1606
    // Utilities (17xx)
    "Electric Utilities"                  => 1701
    "Gas Distributors"                    => 1702
    "Water Utilities"                     => 1703
    "Alternative Power Generation"        => 1704
    // Finance (18xx)
    "Major Banks"                         => 1801
    "Regional Banks"                      => 1802
    "Savings Banks"                       => 1803
    "Finance/Rental/Leasing"              => 1804
    "Investment Banks/Brokers"            => 1805
    "Investment Managers"                 => 1806
    "Financial Conglomerates"             => 1807
    "Property/Casualty Insurance"         => 1808
    "Multi-Line Insurance"                => 1809
    "Life/Health Insurance"               => 1810
    "Specialty Insurance"                 => 1811
    "Insurance Brokers/Services"          => 1812
    "Real Estate Development"             => 1813
    "Real Estate Investment Trusts"       => 1814
    // Communications (19xx)
    "Major Telecommunications"            => 1901
    "Specialty Telecommunications"        => 1902
    "Wireless Telecommunications"         => 1903
    // Miscellaneous (20xx)
    "Miscellaneous"                       => 2001
    "Investment Trusts/Mutual Funds"      => 2002
    => 0

plot(industryCode, title="Industry", color=color.new(#1447df, 0), editable=true)
