//@version=6
indicator('BR - HiLo Intraday 2 Historical', overlay = true)

Lookback1 = input(60, "LookBack1")
Lookback2 = input(120, "LookBack2")
Lookback3 = input(240, "LookBack3")
Offset1 = input(5,"Offset1")
Offset2 = input(10,"Offset2")
Offset3 = input(15,"Offset3")

// Tolerance for convergence detection: two levels are considered equal when
// they differ by less than this percentage of the higher value.
ConvergenceTolerance = input.float(0.05, "Convergence Tolerance %", minval=0.0, step=0.01) / 100


//1
LOOKBACK1 = Lookback1
highest1 = ta.highest(LOOKBACK1)
lowest1 = ta.lowest(LOOKBACK1)

lineTop = line.new(bar_index[LOOKBACK1], highest1, bar_index, highest1, extend = extend.right, color = color.rgb(0, 0, 255), style = line.style_solid, width = 1)
line.delete(lineTop[1])
lineBottom = line.new(bar_index[LOOKBACK1], lowest1, bar_index, lowest1, extend = extend.right, color = color.rgb(255, 0, 0), style = line.style_solid, width = 1)
line.delete(lineBottom[1])

LabelH1 = label.new(bar_index+Offset1, highest1, style = label.style_none)
label.set_text(LabelH1, text = "H" + str.tostring(LOOKBACK1))
label.set_textcolor(LabelH1, color.black)
label.delete(LabelH1[1])

LabelL1 = label.new(bar_index+Offset1, lowest1, style = label.style_none)
label.set_text(LabelL1, text = "L" + str.tostring(LOOKBACK1))
label.set_textcolor(LabelL1, color.black)
label.delete(LabelL1[1])

//1 MidRange
R11 =  (highest1 - lowest1)/2
Range11 = R11 + lowest1
Rangepercent1 = ((close - lowest1)/(highest1 - lowest1))*100
RangeText1 = str.format("{0,number,#.##}", Rangepercent1)

//2
LOOKBACK2 = Lookback2
highest2 = ta.highest(LOOKBACK2)
lowest2 = ta.lowest(LOOKBACK2)

lineTop2 = line.new(bar_index[LOOKBACK2], highest2, bar_index, highest2, extend = extend.right, color = color.rgb(150, 150, 255, 40), style = line.style_solid, width = 6)
line.delete(lineTop2[1])
lineBottom2 = line.new(bar_index[LOOKBACK2], lowest2, bar_index, lowest2, extend = extend.right, color = color.rgb(255, 150, 150, 40), style = line.style_solid, width = 6)
line.delete(lineBottom2[1])

LabelH2 = label.new(bar_index+Offset2, highest2, style = label.style_none)
label.set_text(LabelH2, text = "H" + str.tostring(LOOKBACK2))
label.set_textcolor(LabelH2, color.black)
label.delete(LabelH2[1])

LabelL2 = label.new(bar_index+Offset2, lowest2, style = label.style_none)
label.set_text(LabelL2, text = "L" + str.tostring(LOOKBACK2))
label.set_textcolor(LabelL2, color.black)
label.delete(LabelL2[1])

//2 MidRange
R22 =  (highest2 - lowest2)/2
Range22 = R22 + lowest2
Rangepercent2 = ((close - lowest2)/(highest2 - lowest2))*100
RangeText2 = str.format("{0,number,#.##}", Rangepercent2)


//3
LOOKBACK3 = Lookback3
highest3 = ta.highest(LOOKBACK3)
lowest3 = ta.lowest(LOOKBACK3)

lineTop3 = line.new(bar_index[LOOKBACK3], highest3, bar_index, highest3, extend = extend.right, color = color.rgb(150, 150, 255, 70), style = line.style_solid, width = 12)
line.delete(lineTop3[1])
lineBottom3 = line.new(bar_index[LOOKBACK3], lowest3, bar_index, lowest3, extend = extend.right, color = color.rgb(255, 150, 150, 70), style = line.style_solid, width = 12)
line.delete(lineBottom3[1])

LabelH3 = label.new(bar_index+Offset3, highest3, style = label.style_none)
label.set_text(LabelH3, text = "H" + str.tostring(LOOKBACK3))
label.set_textcolor(LabelH3, color.black)
label.delete(LabelH3[1])

LabelL3 = label.new(bar_index+Offset3, lowest3, style = label.style_none)
label.set_text(LabelL3, text = "L" + str.tostring(LOOKBACK3))
label.set_textcolor(LabelL3, color.black)
label.delete(LabelL3[1])

//3 MidRange
R33 =  (highest3 - lowest3)/2
Range33 = R33 + lowest3
Rangepercent3 = ((close - lowest3)/(highest3 - lowest3))*100
RangeText3 = str.format("{0,number,#.##}", Rangepercent3)


// ─── Convergence Detection ────────────────────────────────────────────────────
// Two levels converge when their absolute difference is within the tolerance
// fraction of the larger of the two values.
levelsClose(a, b) =>
    math.abs(a - b) <= math.max(a, b) * ConvergenceTolerance

// High convergence pairs
highConv12 = levelsClose(highest1, highest2)
highConv13 = levelsClose(highest1, highest3)
highConv23 = levelsClose(highest2, highest3)

// Low convergence pairs
lowConv12 = levelsClose(lowest1, lowest2)
lowConv13 = levelsClose(lowest1, lowest3)
lowConv23 = levelsClose(lowest2, lowest3)

// All-three convergence (at least two pairs align → all three are close)
highConvAll3 = highConv12 and highConv13
lowConvAll3  = lowConv12  and lowConv13

// Any pairwise-only convergence (exclude all-three bars from pairwise series)
highConvAny2 = (highConv12 or highConv13 or highConv23) and not highConvAll3
lowConvAny2  = (lowConv12  or lowConv13  or lowConv23)  and not lowConvAll3

// ─── Plot convergence markers ─────────────────────────────────────────────────
// All-3 convergence: large solid triangle, full opacity
plotshape(highConvAll3, title="All 3 Highs Converge",
     style=shape.triangleup, location=location.abovebar,
     color=color.new(color.blue, 0), size=size.normal)

plotshape(lowConvAll3, title="All 3 Lows Converge",
     style=shape.triangledown, location=location.belowbar,
     color=color.new(color.red, 0), size=size.normal)

// Pairwise convergence: small circle, semi-transparent
plotshape(highConvAny2, title="2 Highs Converge",
     style=shape.circle, location=location.abovebar,
     color=color.new(color.blue, 50), size=size.tiny)

plotshape(lowConvAny2, title="2 Lows Converge",
     style=shape.circle, location=location.belowbar,
     color=color.new(color.red, 50), size=size.tiny)


//Table

var BRTable = table.new(position = position.bottom_left, columns = 4, rows = 5, bgcolor = color.new(color.blue, 90), frame_color = color.white, border_color = color.white, border_width = 2)
if barstate.islast
    table.cell(table_id = BRTable, column = 0, row = 0, text = "Periods", text_color = color.new(color.white, 0) , text_size = size.small, bgcolor = color.new(color.black, 0))
    table.cell(table_id = BRTable, column = 1, row = 0, text = " High ", text_size = size.small, bgcolor = color.new(color.green, 80))
    table.cell(table_id = BRTable, column = 2, row = 0, text = "Low", text_size = size.small, bgcolor = color.new(color.red, 80))
    table.cell(table_id = BRTable, column = 3, row = 0, text = "%Range", text_size = size.small, bgcolor = color.new(#0000ff, 80))
    table.cell(table_id = BRTable, column = 0, row = 1, text = "" + str.tostring(Lookback1), text_size = size.small, bgcolor = color.new(color.blue, 80))
    table.cell(table_id = BRTable, column = 0, row = 2, text = "" + str.tostring(Lookback2), text_size = size.small, bgcolor = color.new(color.blue, 80))
    table.cell(table_id = BRTable, column = 0, row = 3, text = "" + str.tostring(Lookback3), text_size = size.small, bgcolor = color.new(color.blue, 80))

//High
    table.cell(table_id = BRTable, column = 1, row = 1, text = "" + str.tostring(highest1), text_size = size.small)
    table.cell(table_id = BRTable, column = 1, row = 2, text = "" + str.tostring(highest2), text_size = size.small)
    table.cell(table_id = BRTable, column = 1, row = 3, text = "" + str.tostring(highest3), text_size = size.small)


//Low
    table.cell(table_id = BRTable, column = 2, row = 1, text = "" + str.tostring(lowest1), text_size = size.small)
    table.cell(table_id = BRTable, column = 2, row = 2, text = "" + str.tostring(lowest2), text_size = size.small)
    table.cell(table_id = BRTable, column = 2, row = 3, text = "" + str.tostring(lowest3), text_size = size.small)


//%Range
    table.cell(table_id = BRTable, column = 3, row = 1, text = "" + str.tostring(RangeText1), text_size = size.small, bgcolor = Rangepercent1 < 20 ? color.new(color.red, 80) : Rangepercent1 > 80 ? color.new(color.green, 80) : color.new(color.blue, 100))
    table.cell(table_id = BRTable, column = 3, row = 2, text = "" + str.tostring(RangeText2), text_size = size.small, bgcolor = Rangepercent2 < 20 ? color.new(color.red, 80) : Rangepercent2 > 80 ? color.new(color.green, 80) : color.new(color.blue, 100))
    table.cell(table_id = BRTable, column = 3, row = 3, text = "" + str.tostring(RangeText3), text_size = size.small, bgcolor = Rangepercent2 < 20 ? color.new(color.red, 80) : Rangepercent2 > 80 ? color.new(color.green, 80) : color.new(color.blue, 100))
