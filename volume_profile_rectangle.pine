//@version=5
indicator("Volume Profile Rectangle", overlay=true, max_boxes_count=500, max_labels_count=500)

// ============================================================================
// INPUT SETTINGS - Define Rectangle Coordinates
// ============================================================================

// Date Range Inputs
start_date = input.time(timestamp("2024-01-01 00:00"), "Start Date/Time", group="Rectangle Coordinates")
end_date = input.time(timestamp("2024-01-31 23:59"), "End Date/Time", group="Rectangle Coordinates")

// Price Range Inputs
top_price = input.float(100.0, "Top Price", group="Rectangle Coordinates")
bottom_price = input.float(90.0, "Bottom Price", group="Rectangle Coordinates")

// Visual Settings
rect_color = input.color(color.new(color.blue, 85), "Rectangle Color", group="Visual Settings")
rect_border_color = input.color(color.new(color.blue, 30), "Rectangle Border", group="Visual Settings")
label_color = input.color(color.new(color.white, 0), "Label Text Color", group="Visual Settings")
label_bg_color = input.color(color.new(color.blue, 20), "Label Background", group="Visual Settings")

// Volume Calculation Method
volume_method = input.string("Total", "Volume Method", options=["Total", "Bar in Range", "Weighted"],
     tooltip="Total: Sum all volume for bars in range\nBar in Range: Only bars fully within price range\nWeighted: Weight volume by % of bar within price range",
     group="Calculation Settings")

// ============================================================================
// VALIDATION
// ============================================================================

if bottom_price >= top_price
    runtime.error("Bottom Price must be less than Top Price")

// ============================================================================
// CALCULATE VOLUME WITH LIMITED LOOKBACK (EFFICIENT METHOD)
// ============================================================================

// Input for lookback limit
lookback_bars = input.int(500, "Max Lookback Bars", minval=50, maxval=5000,
     tooltip="Maximum number of bars to look back for calculation. Increase if your date range is far in the past.",
     group="Calculation Settings")

// Function to calculate volume for a single bar
calc_bar_volume(bar_h, bar_l, bar_c, bar_v) =>
    float result = 0.0

    if volume_method == "Total"
        result := bar_v

    else if volume_method == "Bar in Range"
        if bar_h <= top_price and bar_l >= bottom_price
            result := bar_v

    else if volume_method == "Weighted"
        bar_range = bar_h - bar_l

        if bar_range > 0
            overlap_top = math.min(bar_h, top_price)
            overlap_bottom = math.max(bar_l, bottom_price)
            overlap_range = math.max(0, overlap_top - overlap_bottom)
            weight = overlap_range / bar_range
            result := bar_v * weight
        else
            if bar_c >= bottom_price and bar_c <= top_price
                result := bar_v
    result

// Calculate total volume within rectangle
total_volume = 0.0
bars_to_check = math.min(bar_index, lookback_bars)

for i = 0 to bars_to_check
    bar_time = time[i]

    // Only include bars within the date range
    if bar_time >= start_date and bar_time <= end_date
        bar_vol = calc_bar_volume(high[i], low[i], close[i], volume[i])
        total_volume += bar_vol

// ============================================================================
// DRAW RECTANGLE
// ============================================================================

var box rect_box = na
var label volume_label = na

// Delete previous box and label on each update
if not na(rect_box)
    box.delete(rect_box)
if not na(volume_label)
    label.delete(volume_label)

// Create new rectangle box
rect_box := box.new(
     left=start_date,
     top=top_price,
     right=end_date,
     bottom=bottom_price,
     bgcolor=rect_color,
     border_color=rect_border_color,
     border_width=2
 )

// ============================================================================
// DISPLAY VOLUME LABEL
// ============================================================================

// Format volume with appropriate units
format_volume(vol) =>
    string result = ""
    if vol >= 1000000000
        result := str.tostring(vol / 1000000000, "#.##") + "B"
    else if vol >= 1000000
        result := str.tostring(vol / 1000000, "#.##") + "M"
    else if vol >= 1000
        result := str.tostring(vol / 1000, "#.##") + "K"
    else
        result := str.tostring(vol, "#")
    result

volume_text = "Volume: " + format_volume(total_volume) + "\n(" + str.tostring(total_volume, "#") + ")"

// Create label at top-right corner of rectangle
volume_label := label.new(
     x=end_date,
     y=top_price,
     text=volume_text,
     style=label.style_label_down,
     color=label_bg_color,
     textcolor=label_color,
     size=size.normal
 )

// ============================================================================
// DEBUG: Plot volume to verify calculation
// ============================================================================

// Uncomment to see volume plotted at the bottom for debugging
// plot(total_volume, "Total Volume", color=color.blue, display=display.data_window)
