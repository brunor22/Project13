//@version=5
indicator("Volume Profile Rectangle", overlay=true, max_boxes_count=500, max_labels_count=500)

// ============================================================================
// INPUT SETTINGS - Define Rectangle Coordinates
// ============================================================================

// Date Range Inputs
start_date = input.time(timestamp("2024-01-01 00:00"), "Start Date/Time", group="Rectangle Coordinates")
end_date = input.time(timestamp("2024-01-31 23:59"), "End Date/Time", group="Rectangle Coordinates")

// Price Range Inputs
top_price = input.float(100.0, "Top Price", group="Rectangle Coordinates")
bottom_price = input.float(90.0, "Bottom Price", group="Rectangle Coordinates")

// Visual Settings
rect_color = input.color(color.new(color.blue, 85), "Rectangle Color", group="Visual Settings")
rect_border_color = input.color(color.new(color.blue, 30), "Rectangle Border", group="Visual Settings")
label_color = input.color(color.new(color.white, 0), "Label Text Color", group="Visual Settings")
label_bg_color = input.color(color.new(color.blue, 20), "Label Background", group="Visual Settings")

// Volume Calculation Method
volume_method = input.string("Total", "Volume Method", options=["Total", "Bar in Range", "Weighted"],
     tooltip="Total: Sum all volume for bars in range\nBar in Range: Only bars fully within price range\nWeighted: Weight volume by % of bar within price range",
     group="Calculation Settings")

// ============================================================================
// VALIDATION
// ============================================================================

if bottom_price >= top_price
    runtime.error("Bottom Price must be less than Top Price")

// ============================================================================
// DRAW RECTANGLE
// ============================================================================

var box rect_box = na
var label volume_label = na

// Delete previous box and label
if not na(rect_box)
    box.delete(rect_box)
if not na(volume_label)
    label.delete(volume_label)

// Create new rectangle box
rect_box := box.new(
     left=start_date,
     top=top_price,
     right=end_date,
     bottom=bottom_price,
     bgcolor=rect_color,
     border_color=rect_border_color,
     border_width=2,
     text="",
     text_color=label_color,
     text_size=size.normal
 )

// ============================================================================
// CALCULATE VOLUME WITHIN RECTANGLE
// ============================================================================

var float total_volume = 0.0
var bool calculation_done = false

// Only calculate once when we're past the end date
if time >= end_date and not calculation_done
    total_volume := 0.0

    // Loop through all bars from start to end date
    for i = 0 to bar_index
        bar_time = time[i]
        bar_high = high[i]
        bar_low = low[i]
        bar_close = close[i]
        bar_volume = volume[i]

        // Check if bar is within date range
        if bar_time >= start_date and bar_time <= end_date

            if volume_method == "Total"
                // Include all volume for bars in the date range
                total_volume += bar_volume

            else if volume_method == "Bar in Range"
                // Only include volume if entire bar is within price range
                if bar_high <= top_price and bar_low >= bottom_price
                    total_volume += bar_volume

            else if volume_method == "Weighted"
                // Weight volume by percentage of bar within price range
                bar_range = bar_high - bar_low

                if bar_range > 0
                    // Calculate overlap between bar and rectangle
                    overlap_top = math.min(bar_high, top_price)
                    overlap_bottom = math.max(bar_low, bottom_price)
                    overlap_range = math.max(0, overlap_top - overlap_bottom)

                    // Calculate percentage of bar within rectangle
                    weight = overlap_range / bar_range
                    total_volume += bar_volume * weight
                else
                    // Bar has no range (high == low), check if within price range
                    if bar_close >= bottom_price and bar_close <= top_price
                        total_volume += bar_volume

    calculation_done := true

// Alternative: Real-time calculation (updates on every bar)
// This version updates continuously instead of waiting until after end_date
float realtime_volume = 0.0

for i = 0 to bar_index
    bar_time = time[i]
    bar_high = high[i]
    bar_low = low[i]
    bar_close = close[i]
    bar_volume = volume[i]

    // Check if bar is within date range
    if bar_time >= start_date and bar_time <= end_date

        if volume_method == "Total"
            realtime_volume += bar_volume

        else if volume_method == "Bar in Range"
            if bar_high <= top_price and bar_low >= bottom_price
                realtime_volume += bar_volume

        else if volume_method == "Weighted"
            bar_range = bar_high - bar_low

            if bar_range > 0
                overlap_top = math.min(bar_high, top_price)
                overlap_bottom = math.max(bar_low, bottom_price)
                overlap_range = math.max(0, overlap_top - overlap_bottom)
                weight = overlap_range / bar_range
                realtime_volume += bar_volume * weight
            else
                if bar_close >= bottom_price and bar_close <= top_price
                    realtime_volume += bar_volume

// ============================================================================
// DISPLAY VOLUME LABEL
// ============================================================================

// Format volume with appropriate units
format_volume(vol) =>
    string result = ""
    if vol >= 1000000000
        result := str.tostring(vol / 1000000000, "#.##") + "B"
    else if vol >= 1000000
        result := str.tostring(vol / 1000000, "#.##") + "M"
    else if vol >= 1000
        result := str.tostring(vol / 1000, "#.##") + "K"
    else
        result := str.tostring(vol, "#")
    result

volume_text = "Volume: " + format_volume(realtime_volume) + "\n(" + str.tostring(realtime_volume, "#") + ")"

// Create label at top-right corner of rectangle
volume_label := label.new(
     x=end_date,
     y=top_price,
     text=volume_text,
     style=label.style_label_down,
     color=label_bg_color,
     textcolor=label_color,
     size=size.normal
 )

// ============================================================================
// OPTIONAL: Plot volume as a line (for reference)
// ============================================================================

// Uncomment to see volume plotted at the bottom
// plot(realtime_volume, "Total Volume", color=color.blue, display=display.data_window)
