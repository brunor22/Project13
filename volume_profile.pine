//@version=5
indicator("Volume Profile", overlay=true, max_bars_back=5000, max_lines_count=500, max_boxes_count=500)

// ========== INPUTS ==========

// Notes: The code will automatically skip rows when needed, but you'll get the best results by keeping rows under:
//          490 rows for single profile
//          245 rows for dual profiles

useTimeRange = input.bool(false, "Use Time Range", tooltip="If true, use start time. If false, use bar lookback")
startTime = input.time(timestamp("2024-01-01 00:00 +0000"), "Start Time", tooltip="Profile start time (only used if 'Use Time Range' is enabled)")
lookback = input.int(100, "Lookback Bars", minval=20, maxval=500, tooltip="Number of bars (only used if 'Use Time Range' is disabled)")

// Row calculation method
useTicksPerRow = input.bool(false, "Use Ticks Per Row", tooltip="If true, use ticks per row. If false, use number of rows")
rows = input.int(24, "Number of Rows", minval=10, maxval=100, tooltip="Number of price levels (only used if 'Use Ticks Per Row' is disabled)")
ticksPerRow = input.float(1.0, "Ticks Per Row", minval=0.01, step=0.01, tooltip="Price increment per row (only used if 'Use Ticks Per Row' is enabled)")

valueArea = input.float(70, "Value Area %", minval=50, maxval=100)
profileWidth = input.int(10, "Profile Width (bars)", minval=5, maxval=400, tooltip="Width of the volume profile bars")
profileOffset = input.int(0, "Profile Offset (bars)", minval=0, maxval=500, tooltip="Shift the profile to the right by this many bars")

// Volume filter
minVolumeThreshold = input.float(0, "Min Volume Threshold", minval=0, tooltip="Only display rows with volume greater than or equal to this value. Set to 0 to show all rows.")

// Secondary profile
showSecondary = input.bool(false, "Show Secondary Profile", tooltip="Display a second profile from a different time period", group="Secondary Profile")
useSecondaryTimeRange = input.bool(true, "Use Time Range", tooltip="If true, use start time. If false, use bar lookback", group="Secondary Profile")
secondaryStartTime = input.time(timestamp("2024-01-01 00:00 +0000"), "Start Time", tooltip="Secondary profile start time", group="Secondary Profile")
secondaryLookback = input.int(50, "Lookback Bars", minval=20, maxval=500, tooltip="Number of bars for secondary profile", group="Secondary Profile")
secondaryWidth = input.int(5, "Secondary Width (bars)", minval=1, maxval=200, tooltip="Width of secondary profile bars", group="Secondary Profile")
secondaryOffsetFromPrimary = input.int(0, "Offset from Primary", minval=-200, maxval=200, tooltip="Position relative to primary profile start (negative = left, positive = right)", group="Secondary Profile")
secondaryColor = input.color(color.new(color.blue, 70), "Secondary Color", group="Secondary Profile")

showDebug = input.bool(false, "Show Debug Info", tooltip="Display calculation details for troubleshooting")

// Display options
showPOC = input.bool(true, "Show POC", inline="1")
pocColor = input.color(color.red, "", inline="1")
showVAH = input.bool(true, "Show VAH", inline="2")
vahColor = input.color(color.green, "", inline="2")
showVAL = input.bool(true, "Show VAL", inline="3")
valColor = input.color(color.blue, "", inline="3")
profileColor = input.color(color.new(color.orange, 60), "Profile Color")

// ========== STORAGE ==========
var box[] boxes = array.new_box()
var line[] lines = array.new_line()
var label[] labels = array.new_label()
var box[] secondaryBoxes = array.new_box()

// ========== FUNCTIONS ==========
deleteDrawings() =>
    for b in boxes
        box.delete(b)
    array.clear(boxes)
    for l in lines
        line.delete(l)
    array.clear(lines)
    for lbl in labels
        label.delete(lbl)
    array.clear(labels)
    for b in secondaryBoxes
        box.delete(b)
    array.clear(secondaryBoxes)

// ========== MAIN LOGIC ==========
if barstate.islast
    deleteDrawings()

    // Calculate lookback range
    barsBack = 0
    if useTimeRange
        // Find the furthest bar back where time >= startTime
        // Limit search to max_bars_back to prevent runtime errors
        startBarIndex = 0
        maxSearch = math.min(bar_index, 4999)
        for i = 0 to maxSearch
            if time[i] >= startTime
                startBarIndex := i
        // barsBack is now the number of bars from startTime to current
        barsBack := startBarIndex
        // Safety check: if no bars found or invalid range, use default lookback
        if barsBack <= 0
            barsBack := math.min(lookback - 1, bar_index)
        // Cap at max_bars_back limit
        barsBack := math.min(barsBack, 4999)
    else
        barsBack := math.min(lookback - 1, bar_index)

    // Find price range - initialize safely and expand through all bars
    hi = high[0]
    lo = low[0]
    for i = 1 to barsBack
        if not na(high[i])
            hi := math.max(hi, high[i])
            lo := math.min(lo, low[i])
    // Calculate number of rows and row height
    actualRows = 0
    rowHeight = 0.0

    if useTicksPerRow
        // Calculate rows based on tick size
        priceRange = hi - lo
        actualRows := math.max(1, int(priceRange / ticksPerRow))
        // Cap at reasonable maximum to prevent performance issues
        actualRows := math.min(actualRows, 500)
        rowHeight := priceRange / actualRows
    else
        // Use fixed number of rows
        actualRows := rows
        rowHeight := (hi - lo) / rows

    if rowHeight > 0
        // Volume array
        vol = array.new_float(actualRows, 0.0)

        // Accumulate volume
        for i = 0 to barsBack
            barHi = high[i]
            barLo = low[i]
            barVol = volume[i]
            barRange = barHi - barLo

            if barRange > 0
                // Distribute volume proportionally
                for r = 0 to actualRows - 1
                    rowLo = lo + r * rowHeight
                    rowHi = lo + (r + 1) * rowHeight

                    if barLo < rowHi and barHi > rowLo
                        overlap = math.min(barHi, rowHi) - math.max(barLo, rowLo)
                        proportion = overlap / barRange
                        array.set(vol, r, array.get(vol, r) + barVol * proportion)
            else
                // Zero-range bar - assign to one row
                rowIdx = math.floor((barLo - lo) / rowHeight)
                rowIdx := math.max(0, math.min(actualRows - 1, rowIdx))
                array.set(vol, rowIdx, array.get(vol, rowIdx) + barVol)

        // Find max volume
        maxVol = array.max(vol)

        // Find POC
        pocIdx = 0
        pocVol = 0.0
        for r = 0 to actualRows - 1
            v = array.get(vol, r)
            if v > pocVol
                pocVol := v
                pocIdx := r

        pocPrice = lo + pocIdx * rowHeight + rowHeight / 2

        // Calculate value area
        totalVol = array.sum(vol)
        targetVol = totalVol * valueArea / 100

        vaVol = array.get(vol, pocIdx)
        vaHi = pocIdx
        vaLo = pocIdx

        while vaVol < targetVol and (vaHi < actualRows - 1 or vaLo > 0)
            hiVol = vaHi < actualRows - 1 ? array.get(vol, vaHi + 1) : 0
            loVol = vaLo > 0 ? array.get(vol, vaLo - 1) : 0

            if hiVol >= loVol and vaHi < actualRows - 1
                vaHi += 1
                vaVol += hiVol
            else if vaLo > 0
                vaLo -= 1
                vaVol += loVol
            else
                break

        vahPrice = lo + vaHi * rowHeight + rowHeight / 2
        valPrice = lo + vaLo * rowHeight + rowHeight / 2

        // Calculate profile positions
        profileStartBar = bar_index + profileOffset
        startBar = bar_index - barsBack
        endBar = profileStartBar + profileWidth

        // ========== SECONDARY PROFILE CALCULATION ==========
        secondaryVol = array.new_float(actualRows, 0.0)
        secondaryMaxVol = 0.0
        combinedMaxVol = maxVol

        if showSecondary
            // Calculate secondary lookback range
            secondaryBarsBack = 0
            if useSecondaryTimeRange
                // Find the furthest bar back where time >= secondaryStartTime
                secondaryStartBarIndex = 0
                maxSecondarySearch = math.min(bar_index, 4999)
                for i = 0 to maxSecondarySearch
                    if time[i] >= secondaryStartTime
                        secondaryStartBarIndex := i
                secondaryBarsBack := secondaryStartBarIndex
                if secondaryBarsBack <= 0
                    secondaryBarsBack := math.min(secondaryLookback - 1, bar_index)
                secondaryBarsBack := math.min(secondaryBarsBack, 4999)
            else
                secondaryBarsBack := math.min(secondaryLookback - 1, bar_index)

            // Accumulate secondary volume using SAME price range as primary
            for i = 0 to secondaryBarsBack
                barHi = high[i]
                barLo = low[i]
                barVol = volume[i]
                barRange = barHi - barLo

                if barRange > 0
                    // Distribute volume proportionally
                    for r = 0 to actualRows - 1
                        rowLo = lo + r * rowHeight
                        rowHi = lo + (r + 1) * rowHeight

                        if barLo < rowHi and barHi > rowLo
                            overlap = math.min(barHi, rowHi) - math.max(barLo, rowLo)
                            proportion = overlap / barRange
                            array.set(secondaryVol, r, array.get(secondaryVol, r) + barVol * proportion)
                else
                    // Zero-range bar - assign to one row
                    rowIdx = math.floor((barLo - lo) / rowHeight)
                    rowIdx := math.max(0, math.min(actualRows - 1, rowIdx))
                    array.set(secondaryVol, rowIdx, array.get(secondaryVol, rowIdx) + barVol)

            // Find max secondary volume
            secondaryMaxVol := array.max(secondaryVol)

            // Use COMBINED max volume for scaling both profiles
            combinedMaxVol := math.max(maxVol, secondaryMaxVol)

        // ========== DRAW PRIMARY PROFILE ==========
        if combinedMaxVol > 0
            for r = 0 to actualRows - 1
                v = array.get(vol, r)
                // Apply volume threshold filter
                if v > 0 and v >= minVolumeThreshold
                    rowLo = lo + r * rowHeight
                    rowHi = lo + (r + 1) * rowHeight

                    // Calculate width using COMBINED max volume for direct comparison with secondary
                    // Ensure minimum width of 1 for any level with volume
                    width = math.max(1, int((v / combinedMaxVol) * profileWidth))

                    x2 = profileStartBar + width

                    // Determine color intensity based on primary's own max
                    intensity = int((v / maxVol) * 100)
                    boxColor = color.new(profileColor, 100 - intensity)

                    // Draw box
                    b = box.new(profileStartBar, rowLo, x2, rowHi, border_color=color.new(profileColor, 30), bgcolor=boxColor, border_width=1, extend=extend.none)
                    array.push(boxes, b)

            // Draw POC, VAH, VAL lines for primary profile
            if showPOC
                pocLine = line.new(startBar, pocPrice, endBar, pocPrice, color=pocColor, width=2, style=line.style_solid)
                array.push(lines, pocLine)
                // Add POC label
                pocLabel = label.new(endBar, pocPrice, "POC: " + str.tostring(pocPrice, format.mintick) + " Vol: " + str.tostring(pocVol, format.volume), style=label.style_label_left, color=pocColor, textcolor=color.white, size=size.small)
                array.push(labels, pocLabel)

            if showVAH
                vahLine = line.new(startBar, vahPrice, endBar, vahPrice, color=vahColor, width=1, style=line.style_dashed)
                array.push(lines, vahLine)
                // Add VAH label
                vahVol = array.get(vol, vaHi)
                vahLabel = label.new(endBar, vahPrice, "VAH: " + str.tostring(vahPrice, format.mintick) + " Vol: " + str.tostring(vahVol, format.volume), style=label.style_label_left, color=vahColor, textcolor=color.white, size=size.small)
                array.push(labels, vahLabel)

            if showVAL
                valLine = line.new(startBar, valPrice, endBar, valPrice, color=valColor, width=1, style=line.style_dashed)
                array.push(lines, valLine)
                // Add VAL label
                valVol = array.get(vol, vaLo)
                valLabel = label.new(endBar, valPrice, "VAL: " + str.tostring(valPrice, format.mintick) + " Vol: " + str.tostring(valVol, format.volume), style=label.style_label_left, color=valColor, textcolor=color.white, size=size.small)
                array.push(labels, valLabel)

        // ========== DRAW SECONDARY PROFILE ==========
        if showSecondary and combinedMaxVol > 0
            secondaryStartBar = profileStartBar + secondaryOffsetFromPrimary

            for r = 0 to actualRows - 1
                v = array.get(secondaryVol, r)
                // Apply volume threshold filter
                if v > 0 and v >= minVolumeThreshold
                    rowLo = lo + r * rowHeight
                    rowHi = lo + (r + 1) * rowHeight

                    // Calculate width using COMBINED max volume for direct comparison
                    // Ensure minimum width of 1 for any level with volume
                    width = math.max(1, int((v / combinedMaxVol) * profileWidth))

                    x2 = secondaryStartBar + width

                    // Determine color intensity based on secondary's own max
                    intensity = int((v / secondaryMaxVol) * 100)
                    boxColor = color.new(secondaryColor, 100 - intensity)

                    // Draw box
                    b = box.new(secondaryStartBar, rowLo, x2, rowHi, border_color=color.new(secondaryColor, 30), bgcolor=boxColor, border_width=1, extend=extend.none)
                    array.push(secondaryBoxes, b)

    // Debug info
    if showDebug
        var table debugTable = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 80), border_width=1)
        table.cell(debugTable, 0, 0, "Range Mode:", text_color=color.white)
        table.cell(debugTable, 1, 0, useTimeRange ? "Time Range" : "Bar Lookback", text_color=color.yellow)
        table.cell(debugTable, 0, 1, "Row Mode:", text_color=color.white)
        table.cell(debugTable, 1, 1, useTicksPerRow ? "Ticks Per Row" : "Fixed Rows", text_color=color.yellow)
        table.cell(debugTable, 0, 2, "Bars Back:", text_color=color.white)
        table.cell(debugTable, 1, 2, str.tostring(barsBack), text_color=color.yellow)
        table.cell(debugTable, 0, 3, "Actual Rows:", text_color=color.white)
        table.cell(debugTable, 1, 3, str.tostring(actualRows), text_color=color.yellow)
        table.cell(debugTable, 0, 4, "Row Height:", text_color=color.white)
        table.cell(debugTable, 1, 4, str.tostring(rowHeight, format.mintick), text_color=color.yellow)
        table.cell(debugTable, 0, 5, "Start Time:", text_color=color.white)
        table.cell(debugTable, 1, 5, str.format_time(startTime, "yyyy-MM-dd HH:mm"), text_color=color.yellow)
        table.cell(debugTable, 0, 6, "Oldest Bar Time:", text_color=color.white)
        table.cell(debugTable, 1, 6, str.format_time(time[math.min(barsBack, bar_index)], "yyyy-MM-dd HH:mm"), text_color=color.yellow)
        table.cell(debugTable, 0, 7, "Current Bar Time:", text_color=color.white)
        table.cell(debugTable, 1, 7, str.format_time(time, "yyyy-MM-dd HH:mm"), text_color=color.yellow)
